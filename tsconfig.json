{
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@/*": [
        "./*",
        "./src/*",
      ]
    },
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
  }
}